{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "outputDirectory": "public",
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "memory": 1024,
      "excludeFiles": "{node_modules/playwright/**,node_modules/playwright-core/**,node_modules/better-sqlite3/**,data/**,public/**}"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/img", "destination": "/api/index" }
  ]
}
